# Default semantic dimensions for Tagnostic's Claude agent.
#
# Each non-blank, non-comment line is one dimension name.
# Content and tags are scored on every dimension listed here,
# producing vectors whose cosine similarity measures relevance.
#
# Copy this file and customise it for your domain:
#   cp agents/dimensions.default my-dimensions.txt
#   export TAGNOSTIC_DIMENSIONS=my-dimensions.txt
#
# Or point TAGNOSTIC_DIMENSIONS at any file with one dimension per line.
